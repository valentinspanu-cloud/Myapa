{
    "name": "laravel/laravel",
    "type": "project",
    "description": "Portal clienti - Laravel 11",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-sockets": "*",
        "barryvdh/laravel-dompdf": "^2.0",
        "bugsnag/bugsnag-laravel": "^2.27",
        "freshbitsweb/laratables": "^4.0",
        "google/recaptcha": "^1.3",
        "intervention/image": "^3.0",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.0",
        "maatwebsite/excel": "^3.1",
        "picqer/php-barcode-generator": "^3.0",
        "predis/predis": "^2.0",
        "spatie/laravel-cookie-consent": "^3.3",
        "spatie/laravel-permission": "^6.0",
        "timehunter/laravel-google-recaptcha-v3": "^2.5",
        "vonage/vonage-laravel": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Http/helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
